---
export interface Props {
  items: { label: string; href?: string }[];
  variant?: 'dark' | 'light';
  class?: string;
}

const { items, variant = 'light', class: className = '' } = Astro.props;

const textColors = variant === 'dark' ? 'text-foreground/60 hover:text-foreground' : 'text-gray-500 hover:text-gray-900';
const activeTextColor = variant === 'dark' ? 'text-primary' : 'text-blue-600';
const separatorColor = variant === 'dark' ? 'text-foreground/30' : 'text-gray-600';
---

<nav class={`flex items-center text-sm font-medium ${className}`} aria-label="Breadcrumb">
  <ol class="flex items-center space-x-2">
    <li>
      <a href="/" class={`transition-colors ${textColors}`}>
        Home
      </a>
    </li>
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li class="flex items-center space-x-2">
          <svg class={`w-4 h-4 ${separatorColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          {isLast || !item.href ? (
            <span class={`${activeTextColor}`} aria-current={isLast ? 'page' : undefined}>
              {item.label}
            </span>
          ) : (
            <a href={item.href} class={`transition-colors ${textColors}`}>
              {item.label}
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>

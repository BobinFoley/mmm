---
// BlogPreview.astro
const posts = [
  {
    title: "The STAB Framework: How to Audit and Fix Any Google Ads Account for Contractors",
    slug: "stab-framework-google-ads-audit",
    category: "Lead Generation",
    readTime: "18 min read",
    date: "January 15, 2025",
    excerpt: "Most Google Ads accounts for contractors are bleeding money in places you'd never think to look. The STAB Framework — Spend, Targeting, Ads, and Bidding — gives you a systematic, repeatable way to audit any account and find exactly where the waste is hiding."
  },
  {
    title: "Why Most Contractor Websites Fail (And the 7 Things That Actually Convert Visitors Into Calls)",
    slug: "contractor-websites-that-convert",
    category: "Lead Generation",
    readTime: "14 min read",
    date: "January 8, 2025",
    excerpt: "Your website isn't a brochure — it's a conversion machine. Or at least it should be. Most contractor websites fail because they're built for aesthetics instead of action. Here are the 7 structural elements that separate lead-generating sites from digital dead weight."
  },
  {
    title: "Call Tracking for Contractors: The Complete Guide to Knowing Exactly Where Your Leads Come From",
    slug: "call-tracking-complete-guide",
    category: "Call Tracking",
    readTime: "16 min read",
    date: "December 28, 2024",
    excerpt: "If you're spending money on advertising without call tracking, you're flying blind. This guide breaks down exactly how call tracking works, what data it gives you, and why it's the single most important tool in any contractor's marketing stack."
  }
];
---
<section class="py-24 bg-white/5 border-t border-white/10 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 mb-12">
      <div>
        <h3 class="text-amber-500 font-bold uppercase tracking-widest text-sm mb-3">Contractor Marketing Insights</h3>
        <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight">Latest from the <span class="text-amber-500">Blog</span></h2>
      </div>
      <a href="/blog" class="text-amber-500 font-semibold hover:text-amber-400 transition-colors flex items-center gap-1 group whitespace-nowrap">
        View all posts <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="group flex flex-col h-full bg-[#020617] rounded-2xl p-7 border border-white/10 hover:border-amber-500/40 hover:shadow-xl hover:shadow-amber-500/5 transition-all duration-300">
          <div class="flex justify-between items-center mb-6">
            <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold tracking-wider uppercase bg-amber-500/10 text-amber-500">
              {post.category}
            </span>
            <div class="flex items-center gap-1.5 text-xs text-slate-400 font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {post.readTime}
            </div>
          </div>
          
          <h3 class="text-xl font-black text-white mb-4 line-clamp-3 leading-tight group-hover:text-amber-500 transition-colors">
            {post.title}
          </h3>
          
          <p class="text-slate-400 text-sm leading-relaxed mb-8 line-clamp-3 flex-grow">
            {post.excerpt}
          </p>
          
          <div class="mt-auto pt-6 border-t border-white/10 flex justify-between items-center">
            <span class="text-slate-500 text-xs font-semibold">{post.date}</span>
            <span class="text-amber-500 text-sm font-bold flex items-center gap-1 group-hover:underline underline-offset-4 decoration-amber-500/50">
              Read <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center">
      <a href="/blog" class="inline-flex items-center justify-center px-10 py-5 bg-white text-[#020617] hover:bg-slate-200 font-black rounded-full transition-transform hover:scale-95 gap-2 shadow-xl">
        See All Articles
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>
